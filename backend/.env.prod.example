# Copie para .env.prod e preencha com as credenciais da equipe (Supabase).
# NÃO commite o .env.prod — ele contém senhas.
#
# Peça o arquivo pronto ou as URLs no canal seguro do grupo (Discord).

PORT=3000

# URL pública da API — necessária para o Swagger UI em /api-docs
API_URL=https://euamopiri-backend.onrender.com

# CORS — URL exata do frontend no Render
CORS_ORIGIN=https://euamopiri-frontend.onrender.com

# API em produção — pooler (porta 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migrations — conexão direta (porta 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
