# Copie este arquivo para .env e ajuste se necessário:
#   cp .env.example .env

# Porta da API (opcional — padrão 3000)
PORT=3000

# Connection string do PostgreSQL
# Valores abaixo correspondem ao container Docker documentado no README.md

DATABASE_URL="postgres://postgres:postgres@localhost:5432/euamopiri"

# Autenticação JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# CORS — origem do frontend de teste
CORS_ORIGIN=http://localhost:5173

# URL pública da API (produção) — usada pelo Swagger UI em /api-docs
# No Render, RENDER_EXTERNAL_URL já é definida automaticamente; API_URL é opcional.
# API_URL=https://euamopiri-backend.onrender.com

# Google Cloud Storage — fotos (bucket único, prefixos por tipo)
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
GCS_PROFILE_PREFIX=profile_photo/
GCS_PLACE_PREFIX=place_photos/
GCS_EXPERIENCE_PREFIX=experience_photos/
GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-service-account.json

# Conta admin: não há cadastro público. Após criar um usuário normal, promova via SQL:
# UPDATE "User" SET "accountType" = 'ADMIN' WHERE email = 'admin@exemplo.com';
