// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  TURISTA
  MORADOR
  ADMIN
}

enum PlaceCategory {
  CACHOEIRA
  RESTAURANTE
  POUSADA
}

model Place {
  id          Int           @id @default(autoincrement())
  name        String
  category    PlaceCategory
  description String
  address     String
  mapsLink    String?
  phone       String?
  openingDate DateTime?
  moradorId   Int
  morador     User          @relation(fields: [moradorId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  experiences Experiences[]
  photos      PlacePhoto[]
}

model PlacePhoto {
  id        Int    @id @default(autoincrement())
  placeId   Int
  place     Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int
}

model User {
  id              Int           @id @default(autoincrement())
  accountType     AccountType?
  name            String
  email           String        @unique
  birthDate       DateTime?
  phone           String?
  profession      String?
  biography       String?
  profilePhotoUrl String?
  passwordHash    String?
  googleId        String?       @unique
  createdAt       DateTime      @default(now())
  experiences     Experiences[]
  places          Place[]
}

model Experiences {
  id        Int                @id @default(autoincrement())
  userName  String
  rating    Int
  title     String?
  text      String
  visitDate DateTime
  createdAt DateTime           @default(now())
  placeId   Int
  place     Place              @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  photos    ExperiencePhoto[]
}

model ExperiencePhoto {
  id           Int         @id @default(autoincrement())
  experienceId Int
  experience   Experiences @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  url          String
  sortOrder    Int
}
