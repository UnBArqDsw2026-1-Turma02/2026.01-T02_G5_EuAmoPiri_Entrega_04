// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  TURISTA
  MORADOR
  ADMIN
}

enum PlaceCategory {
  CACHOEIRA
  RESTAURANTE
  POUSADA
}

enum ReactionType {
  HEART
  LIKE
}

model Place {
  id          Int           @id @default(autoincrement())
  name        String
  category    PlaceCategory
  description String
  address     String
  mapsLink    String?
  phone       String?
  openingDate DateTime?
  moradorId   Int
  morador     User          @relation(fields: [moradorId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  experiences Experiences[]
  photos      PlacePhoto[]
}

model PlacePhoto {
  id        Int    @id @default(autoincrement())
  placeId   Int
  place     Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int
}

model User {
  id              Int           @id @default(autoincrement())
  accountType     AccountType?
  name            String
  email           String        @unique
  birthDate       DateTime?
  phone           String?
  profession      String?
  biography       String?
  profilePhotoUrl String?
  passwordHash    String?
  createdAt           DateTime             @default(now())
  experiences         Experiences[]
  places              Place[]
  experienceComments  ExperienceComment[]
  experienceReactions ExperienceReaction[]
}

model Experiences {
  id        Int                @id @default(autoincrement())
  userName  String
  rating    Int
  title     String?
  text      String
  visitDate DateTime
  createdAt DateTime           @default(now())
  placeId   Int
  place     Place              @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    Int?
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  photos    ExperiencePhoto[]
  comments  ExperienceComment[]
  reactions ExperienceReaction[]
}

model ExperienceComment {
  id           Int         @id @default(autoincrement())
  text         String
  experienceId Int
  experience   Experiences @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  userId       Int
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
}

model ExperienceReaction {
  id           Int          @id @default(autoincrement())
  experienceId Int
  experience   Experiences  @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  userId       Int
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         ReactionType
  createdAt    DateTime     @default(now())

  @@unique([experienceId, userId])
}

model ExperiencePhoto {
  id           Int         @id @default(autoincrement())
  experienceId Int
  experience   Experiences @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  url          String
  sortOrder    Int
}
